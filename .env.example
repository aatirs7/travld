# ─── Database (Neon Postgres) ────────────────────────────────────────────────
# Pooled connection string from the Neon dashboard. Used by Drizzle for
# migrations, seeding, and app queries. Node >= 19 required for @neondatabase/serverless.
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/travld?sslmode=require"

# ─── Mobile app ──────────────────────────────────────────────────────────────
# Base URL the Expo app calls for API routes (points at apps/web in prod).
EXPO_PUBLIC_API_URL="http://localhost:3000"

# ─── Cloudflare R2 (photos) — Phase 5, not needed yet ────────────────────────
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET="travld-photos"
# R2_PUBLIC_URL=""

# ─── Clerk (auth) — Phase 5, not needed yet ──────────────────────────────────
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=""
# CLERK_SECRET_KEY=""
# CLERK_JWT_KEY=""
